generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  KOREA_SUPPLY_ADMIN
  COUNTRY_ADMIN
  ADMIN
  BUYER
  SUPPLIER
}

enum OrderStatus {
  CREATED
  UNDER_REVIEW
  ASSIGNED
  SUPPLIER_CONFIRMED
  SHIPPED
  DELIVERED
  PENDING
  REVIEWING
  PARTIAL_SENT
  SENT
  CANCELLED
}

enum OrderItemStatus {
  CREATED
  ASSIGNED
  SUPPLIER_CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AssignmentMode {
  MANUAL
  AUTO_PRODUCT
  AUTO_TIMEOUT
}

enum ProductStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ProductApprovalAction {
  SUBMIT
  APPROVE
  REJECT
}

enum OrderSupplierStatus {
  WAITING
  SENT
  SUPPLIER_CONFIRMED
  DELIVERING
  COMPLETED
  CANCELLED
}

enum ShipmentStatus {
  CREATED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum BuyerOrderStatus {
  ORDER_CREATED
  PAYMENT_PENDING
  PAYMENT_COMPLETED
  ORDER_CANCELLED
}

enum SupplierShipmentStatus {
  CONFIRMED
  PREPARING
  PACKING
  SHIPPED
  DELIVERED
  HOLD
}

enum NotificationEvent {
  ORDER_CREATED
  ORDER_ASSIGNED
  SUPPLIER_CONFIRMED
  SHIPMENT_SHIPPED
  SHIPMENT_DELIVERED
  ORDER_DELAYED
  SHIPMENT_DELAYED
}

enum OrderEventType {
  ORDER_CREATED
  ORDER_REVIEWED
  ORDER_ASSIGNED
  SUPPLIER_CONFIRMED
  SHIPMENT_CREATED
  SHIPMENT_SHIPPED
  SHIPMENT_DELIVERED
}

enum QuoteCreatorRole {
  ADMIN
  SUPPLIER
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

enum EmailRelatedType {
  ORDER
  QUOTE
}

enum EmailStatus {
  SUCCESS
  FAILED
  PENDING
}

enum InvoiceFileType {
  PDF
  XML
}

enum InvoiceOrderLinkType {
  AUTO
  MANUAL
}

enum ProjectStatus {
  DRAFT
  QUOTING
  QUOTED
  ORDERING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProjectFileType {
  PDF
  DWG
  ZIP
  PNG
  JPG
  JPEG
}

enum SupplierStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Country {
  id           Int       @id @default(autoincrement())
  country_code String    @unique
  country_name String
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  users        User[]
  orders       Order[]
  quotes       Quote[]
  projects     Project[]
}

model Supplier {
  id                          Int             @id @default(autoincrement())
  company_name                String
  company_code                String?         @unique
  country_code                String          @default("KR")
  business_number             String?
  representative_name         String?
  contact_name                String?
  contact_email               String?
  contact_phone               String?
  address                     String?
  status                      SupplierStatus  @default(PENDING)
  supplier_code               String?         @unique
  supplier_name               String
  order_email                 String
  cc_email                    String?
  invoice_sender_email        String?
  is_active                   Boolean         @default(true)
  allow_supplier_product_edit Boolean         @default(false)
  created_at                  DateTime        @default(now())
  updated_at                  DateTime        @updatedAt
  users                       User[]
  categories                  Category[]
  products                    Product[]
  order_items                 OrderItem[]
  order_assignments           OrderAssignment[]
  order_suppliers             OrderSupplier[]
  quote_items                 QuoteItem[]
  quotes                      Quote[]
  email_logs                  EmailLog[]
  invoice_senders             SupplierInvoiceSender[]
  email_inboxes               EmailInbox[]
  tax_invoices                TaxInvoice[]
  purchase_orders             PurchaseOrder[]
  purchase_order_templates    PurchaseOrderTemplate[]

  @@index([status, country_code])
}

model SupplierInvoiceSender {
  id          Int      @id @default(autoincrement())
  supplier_id Int
  sender_email String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  supplier    Supplier @relation(fields: [supplier_id], references: [id])

  @@unique([sender_email])
  @@index([supplier_id, is_active])
}

model Category {
  id            Int        @id @default(autoincrement())
  supplier_id   Int
  category_name String
  sort_order    Int        @default(0)
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  supplier      Supplier   @relation(fields: [supplier_id], references: [id])
  products      Product[]
  order_items   OrderItem[]
  quote_items   QuoteItem[]

  @@unique([supplier_id, category_name])
  @@index([supplier_id, is_active])
}

model Product {
  id                Int        @id @default(autoincrement())
  supplier_id       Int
  category_id       Int
  country_code      String
  name              String?
  sku               String?
  description       String?
  specification     String?
  product_code      String
  product_name      String
  thumbnail_url     String?
  currency          String     @default("KRW")
  status            ProductStatus @default(APPROVED)
  rejection_reason  String?
  product_image_url String?
  spec              String
  unit              String
  price             Decimal    @db.Decimal(18, 2)
  memo              String?
  is_active         Boolean    @default(true)
  sort_order        Int        @default(0)
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt
  supplier          Supplier   @relation(fields: [supplier_id], references: [id])
  category          Category   @relation(fields: [category_id], references: [id])
  order_items       OrderItem[]
  quote_items       QuoteItem[]
  approval_logs     ProductApprovalLog[]

  @@unique([supplier_id, product_code])
  @@index([supplier_id, status])
  @@index([country_code, is_active, status])
  @@index([supplier_id, category_id, is_active])
  @@index([product_name])
}

model User {
  id                    Int              @id @default(autoincrement())
  login_id              String           @unique
  password_hash         String
  name                  String
  email                 String?
  role                  Role
  country_id            Int?
  supplier_id           Int?
  is_active             Boolean          @default(true)
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt
  country               Country?         @relation(fields: [country_id], references: [id])
  supplier              Supplier?        @relation(fields: [supplier_id], references: [id])
  buyer_orders          Order[]          @relation("BuyerOrders")
  buyer_quotes          Quote[]          @relation("BuyerQuotes")
  projects              Project[]         @relation("BuyerProjects")
  created_projects      Project[]         @relation("ProjectCreatedBy")
  created_quotes        Quote[]          @relation("CreatorQuotes")
  order_change_logs     OrderChangeLog[] @relation("OrderChangeBy")
  sent_order_suppliers  OrderSupplier[]  @relation("OrderSentBy")
  checked_order_records OrderSupplier[]  @relation("SupplierCheckedBy")
  order_assignments     OrderAssignment[] @relation("OrderAssignmentBy")
  project_files         ProjectFile[]    @relation("ProjectFileUploadedBy")
  audit_logs            AuditLog[]       @relation("AuditActor")
  created_purchase_orders PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  product_approval_logs ProductApprovalLog[] @relation("ProductApprovalActor")
  updated_system_settings SystemSetting[] @relation("SystemSettingUpdatedBy")
  shipment_status_logs  ShipmentStatusLog[] @relation("ShipmentStatusLogCreatedBy")
  notification_recipients NotificationRecipient[]
  order_event_logs     OrderEventLog[] @relation("OrderEventCreatedBy")
  buyer_status_updated_orders Order[] @relation("BuyerOrderStatusUpdatedBy")
  supplier_status_updated_shipments Shipment[] @relation("SupplierShipmentStatusUpdatedBy")

  @@index([role, is_active])
  @@index([country_id])
  @@index([supplier_id])
}

model SystemSetting {
  id         Int      @id @default(autoincrement())
  setting_key String  @unique
  value_json Json
  updated_by Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  updater    User?    @relation("SystemSettingUpdatedBy", fields: [updated_by], references: [id])
}

model ProductApprovalLog {
  id            Int                   @id @default(autoincrement())
  product_id    Int
  action        ProductApprovalAction
  actor_user_id Int
  reason        String?
  created_at    DateTime              @default(now())
  product       Product               @relation(fields: [product_id], references: [id])
  actor         User                  @relation("ProductApprovalActor", fields: [actor_user_id], references: [id])

  @@index([product_id, created_at])
  @@index([actor_user_id, created_at])
}

model Project {
  id          Int           @id @default(autoincrement())
  project_name String
  buyer_id    Int
  country_id  Int
  status      ProjectStatus @default(DRAFT)
  memo        String?
  location    String?
  start_date  DateTime?
  end_date    DateTime?
  created_by  Int
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  buyer       User          @relation("BuyerProjects", fields: [buyer_id], references: [id])
  creator     User          @relation("ProjectCreatedBy", fields: [created_by], references: [id])
  country     Country       @relation(fields: [country_id], references: [id])
  orders      Order[]
  quotes      Quote[]
  files       ProjectFile[]

  @@index([buyer_id, country_id, status])
  @@index([created_by, created_at])
}

model ProjectFile {
  id          Int      @id @default(autoincrement())
  project_id  Int
  file_name   String
  original_name String
  file_size   Int
  file_type   ProjectFileType
  file_url    String
  uploaded_by Int
  created_at  DateTime @default(now())
  project     Project  @relation(fields: [project_id], references: [id])
  uploader    User     @relation("ProjectFileUploadedBy", fields: [uploaded_by], references: [id])

  @@index([project_id, created_at])
}

model Order {
  id            Int              @id @default(autoincrement())
  order_no      String           @unique
  buyer_id      Int
  country_id    Int
  country_code  String
  project_id    Int?
  status        OrderStatus      @default(PENDING)
  buyer_status  BuyerOrderStatus @default(ORDER_CREATED)
  buyer_status_updated_by Int?
  buyer_status_updated_at DateTime?
  memo          String?
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  buyer         User             @relation("BuyerOrders", fields: [buyer_id], references: [id])
  country       Country          @relation(fields: [country_id], references: [id])
  project       Project?         @relation(fields: [project_id], references: [id])
  order_items   OrderItem[]
  suppliers     OrderSupplier[]
  change_logs   OrderChangeLog[]
  tax_invoices  TaxInvoice[]
  purchase_orders PurchaseOrder[]
  event_logs    OrderEventLog[]
  buyer_status_updater User?     @relation("BuyerOrderStatusUpdatedBy", fields: [buyer_status_updated_by], references: [id])

  @@index([buyer_id, country_id, status])
  @@index([buyer_id, buyer_status])
  @@index([project_id])
}

model OrderItem {
  id                    Int      @id @default(autoincrement())
  order_id              Int
  supplier_id           Int
  status                OrderItemStatus @default(CREATED)
  assigned_by           Int?
  assigned_at           DateTime?
  assignment_mode       AssignmentMode?
  category_id           Int?
  product_id            Int
  product_code_snapshot String
  product_name_snapshot String
  spec_snapshot         String
  unit_snapshot         String
  price_snapshot        Decimal  @db.Decimal(18, 2)
  qty                   Decimal  @db.Decimal(18, 3)
  amount                Decimal  @db.Decimal(18, 2)
  memo                  String?
  created_at            DateTime @default(now())
  order                 Order    @relation(fields: [order_id], references: [id])
  supplier              Supplier @relation(fields: [supplier_id], references: [id])
  category              Category? @relation(fields: [category_id], references: [id])
  product               Product  @relation(fields: [product_id], references: [id])
  change_logs           OrderChangeLog[]
  assignments           OrderAssignment[]
  shipment_items        ShipmentItem[]

  @@index([order_id, supplier_id])
  @@index([order_id, status])
  @@index([supplier_id, status])
  @@index([product_id])
}

model OrderAssignment {
  id            Int      @id @default(autoincrement())
  order_item_id Int
  supplier_id   Int
  assigned_by   Int
  assigned_at   DateTime @default(now())
  order_item    OrderItem @relation(fields: [order_item_id], references: [id])
  supplier      Supplier @relation(fields: [supplier_id], references: [id])
  assignee      User     @relation("OrderAssignmentBy", fields: [assigned_by], references: [id])

  @@index([order_item_id, assigned_at])
  @@index([supplier_id, assigned_at])
  @@index([assigned_by, assigned_at])
}

model OrderSupplier {
  id                  Int                 @id @default(autoincrement())
  order_id            Int
  supplier_id         Int
  status              OrderSupplierStatus @default(WAITING)
  sent_at             DateTime?
  sent_by             Int?
  email_sent          Boolean             @default(false)
  portal_visible      Boolean             @default(false)
  supplier_checked    Boolean             @default(false)
  supplier_checked_at DateTime?
  supplier_checked_by Int?
  supplier_confirmed_at DateTime?
  expected_delivery_date DateTime?
  supplier_note      String?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  order               Order               @relation(fields: [order_id], references: [id])
  supplier            Supplier            @relation(fields: [supplier_id], references: [id])
  sender              User?               @relation("OrderSentBy", fields: [sent_by], references: [id])
  checker             User?               @relation("SupplierCheckedBy", fields: [supplier_checked_by], references: [id])
  shipments           Shipment[]

  @@unique([order_id, supplier_id])
  @@index([status])
}

model Shipment {
  id               Int            @id @default(autoincrement())
  order_supplier_id Int
  shipment_no      String         @unique
  carrier          String?
  tracking_number  String?
  status           ShipmentStatus @default(CREATED)
  supplier_status  SupplierShipmentStatus @default(CONFIRMED)
  supplier_status_updated_by Int?
  supplier_status_updated_at DateTime?
  shipped_at       DateTime?
  delivered_at     DateTime?
  created_at       DateTime       @default(now())
  order_supplier   OrderSupplier  @relation(fields: [order_supplier_id], references: [id])
  supplier_status_updater User? @relation("SupplierShipmentStatusUpdatedBy", fields: [supplier_status_updated_by], references: [id])
  items            ShipmentItem[]
  status_logs      ShipmentStatusLog[]

  @@index([order_supplier_id, created_at])
  @@index([status, created_at])
  @@index([supplier_status, created_at])
}

model ShipmentItem {
  id           Int      @id @default(autoincrement())
  shipment_id  Int
  order_item_id Int
  quantity     Decimal  @db.Decimal(18, 3)
  created_at   DateTime @default(now())
  shipment     Shipment @relation(fields: [shipment_id], references: [id])
  order_item   OrderItem @relation(fields: [order_item_id], references: [id])

  @@unique([shipment_id, order_item_id])
  @@index([order_item_id, created_at])
}

model ShipmentStatusLog {
  id             Int      @id @default(autoincrement())
  shipment_id    Int
  status_message String
  created_by     Int
  created_at     DateTime @default(now())
  shipment       Shipment @relation(fields: [shipment_id], references: [id])
  creator        User     @relation("ShipmentStatusLogCreatedBy", fields: [created_by], references: [id])

  @@index([shipment_id, created_at])
  @@index([created_by, created_at])
}

model Notification {
  id         Int               @id @default(autoincrement())
  event_type NotificationEvent
  entity_type String
  entity_id  Int
  message    String
  created_at DateTime          @default(now())
  recipients NotificationRecipient[]

  @@index([event_type, created_at])
  @@index([entity_type, entity_id])
}

model NotificationRecipient {
  id              Int          @id @default(autoincrement())
  notification_id Int
  user_id         Int
  is_read         Boolean      @default(false)
  created_at      DateTime     @default(now())
  notification    Notification @relation(fields: [notification_id], references: [id])
  user            User         @relation(fields: [user_id], references: [id])

  @@unique([notification_id, user_id])
  @@index([user_id, is_read, created_at])
  @@index([notification_id])
}

model OrderEventLog {
  id         Int            @id @default(autoincrement())
  order_id   Int
  event_type OrderEventType
  message    String
  created_by Int
  created_at DateTime       @default(now())
  order      Order          @relation(fields: [order_id], references: [id])
  creator    User           @relation("OrderEventCreatedBy", fields: [created_by], references: [id])

  @@index([order_id, created_at])
  @@index([event_type, created_at])
  @@index([created_by, created_at])
}

model Quote {
  id           Int            @id @default(autoincrement())
  quote_no     String         @unique
  buyer_id     Int
  country_id   Int
  project_id   Int?
  created_by   Int
  creator_role QuoteCreatorRole
  supplier_id  Int?
  status       QuoteStatus    @default(DRAFT)
  memo         String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  buyer        User           @relation("BuyerQuotes", fields: [buyer_id], references: [id])
  country      Country        @relation(fields: [country_id], references: [id])
  project      Project?       @relation(fields: [project_id], references: [id])
  creator      User           @relation("CreatorQuotes", fields: [created_by], references: [id])
  supplier     Supplier?      @relation(fields: [supplier_id], references: [id])
  quote_items  QuoteItem[]

  @@index([buyer_id, country_id, status])
  @@index([project_id])
}

model QuoteItem {
  id                    Int      @id @default(autoincrement())
  quote_id              Int
  supplier_id           Int
  category_id           Int?
  product_id            Int
  product_code_snapshot String
  product_name_snapshot String
  spec_snapshot         String
  unit_snapshot         String
  price_snapshot        Decimal  @db.Decimal(18, 2)
  qty                   Decimal  @db.Decimal(18, 3)
  amount                Decimal  @db.Decimal(18, 2)
  created_at            DateTime @default(now())
  quote                 Quote    @relation(fields: [quote_id], references: [id])
  supplier              Supplier @relation(fields: [supplier_id], references: [id])
  category              Category? @relation(fields: [category_id], references: [id])
  product               Product  @relation(fields: [product_id], references: [id])

  @@index([quote_id, supplier_id])
}

model EmailLog {
  id            Int              @id @default(autoincrement())
  related_type  EmailRelatedType
  related_id    Int
  supplier_id   Int?
  to_email      String
  cc_email      String?
  subject       String
  body_preview  String?
  status        EmailStatus      @default(PENDING)
  error_message String?
  sent_at       DateTime?
  created_at    DateTime         @default(now())
  supplier      Supplier?        @relation(fields: [supplier_id], references: [id])

  @@index([related_type, related_id])
}

model EmailInbox {
  id               Int         @id @default(autoincrement())
  message_id       String?     @unique
  from_email       String
  to_email         String
  subject          String
  body             String?
  supplier_id      Int?
  received_at      DateTime
  attachment_count Int         @default(0)
  processed        Boolean     @default(false)
  created_at       DateTime    @default(now())
  supplier         Supplier?   @relation(fields: [supplier_id], references: [id])
  tax_invoice      TaxInvoice?

  @@index([from_email, received_at])
  @@index([supplier_id, received_at])
}

model TaxInvoice {
  id             Int          @id @default(autoincrement())
  supplier_id    Int?
  order_id       Int?
  order_link_type InvoiceOrderLinkType?
  invoice_number String?
  email_inbox_id Int          @unique
  issue_date     DateTime?
  amount         Decimal?     @db.Decimal(18, 2)
  vat            Decimal?     @db.Decimal(18, 2)
  total          Decimal?     @db.Decimal(18, 2)
  created_at     DateTime     @default(now())
  supplier       Supplier?    @relation(fields: [supplier_id], references: [id])
  order          Order?       @relation(fields: [order_id], references: [id])
  email_inbox    EmailInbox   @relation(fields: [email_inbox_id], references: [id])
  files          InvoiceFile[]

  @@index([supplier_id, created_at])
  @@index([order_id])
}

model InvoiceFile {
  id         Int             @id @default(autoincrement())
  invoice_id Int
  file_name  String
  file_url   String
  file_type  InvoiceFileType
  created_at DateTime        @default(now())
  invoice    TaxInvoice      @relation(fields: [invoice_id], references: [id])

  @@index([invoice_id, file_type])
}

model PurchaseOrder {
  id         Int      @id @default(autoincrement())
  order_id   Int
  supplier_id Int
  file_name  String
  file_url   String
  created_by Int
  created_at DateTime @default(now())
  order      Order    @relation(fields: [order_id], references: [id])
  supplier   Supplier @relation(fields: [supplier_id], references: [id])
  creator    User     @relation("PurchaseOrderCreatedBy", fields: [created_by], references: [id])

  @@unique([order_id, supplier_id])
  @@index([supplier_id, created_at])
}

model PurchaseOrderTemplate {
  id            Int       @id @default(autoincrement())
  supplier_id   Int?
  template_name String
  title_ko      String    @default("발주서")
  title_en      String    @default("Purchase Order")
  buyer_name    String?
  footer_note   String?
  is_default    Boolean   @default(false)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  supplier      Supplier? @relation(fields: [supplier_id], references: [id])

  @@index([supplier_id, is_active])
  @@index([is_default, is_active])
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actor_id    Int
  action_type String
  target_type String
  target_id   Int
  before_data Json?
  after_data  Json?
  created_at  DateTime @default(now())
  actor       User     @relation("AuditActor", fields: [actor_id], references: [id])

  @@index([target_type, target_id])
  @@index([actor_id, created_at])
}

model OrderChangeLog {
  id            Int       @id @default(autoincrement())
  order_id      Int
  order_item_id Int?
  action_type   String
  before_data   Json?
  after_data    Json?
  changed_by    Int
  created_at    DateTime  @default(now())
  order         Order     @relation(fields: [order_id], references: [id])
  order_item    OrderItem? @relation(fields: [order_item_id], references: [id])
  changed_user  User      @relation("OrderChangeBy", fields: [changed_by], references: [id])

  @@index([order_id, created_at])
}
