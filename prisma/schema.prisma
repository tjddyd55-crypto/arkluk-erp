generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  KOREA_SUPPLY_ADMIN
  COUNTRY_ADMIN
  ADMIN
  BUYER
  SUPPLIER
}

enum Language {
  ko
  en
  mn
  ar
}

enum OrderStatus {
  CREATED
  UNDER_REVIEW
  ASSIGNED
  SUPPLIER_CONFIRMED
  SHIPPED
  DELIVERED
  PENDING
  REVIEWING
  PARTIAL_SENT
  SENT
  CANCELLED
}

enum OrderItemStatus {
  CREATED
  ASSIGNED
  SUPPLIER_CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum AssignmentMode {
  MANUAL
  AUTO_PRODUCT
  AUTO_TIMEOUT
}

enum ProductStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

/** 사업자·상품 라인: 건축자재 vs 기타(일반)상품. Taxonomy `Category` 모델과 별개 */
enum ProductCategory {
  CONSTRUCTION
  GENERAL
}

enum ProductApprovalAction {
  SUBMIT
  APPROVE
  REJECT
}

enum OrderSupplierStatus {
  PENDING
  SENT
  VIEWED
  CONFIRMED
  REJECTED
  SHIPPING
  COMPLETED
  CANCELLED
}

/** 공급사 구간·통합 발주서 PDF 생성 상태 */
enum OsPdfStatus {
  PENDING
  SUCCESS
  FAILED
}

/** 공급사 발주 메일 전달 상태 */
enum OsEmailStatus {
  PENDING
  SENT
  FAILED
}

enum PoPdfDownloadType {
  COMBINED
  SUPPLIER_SECTION
}

enum ShipmentStatus {
  CREATED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum BuyerOrderStatus {
  ORDER_CREATED
  PAYMENT_PENDING
  PAYMENT_COMPLETED
  ORDER_CANCELLED
}

enum SupplierShipmentStatus {
  CONFIRMED
  PREPARING
  PACKING
  SHIPPED
  DELIVERED
  HOLD
}

enum NotificationEvent {
  ORDER_CREATED
  ORDER_ASSIGNED
  SUPPLIER_CONFIRMED
  SUPPLIER_REJECTED
  SHIPMENT_SHIPPED
  SHIPMENT_DELIVERED
  ORDER_DELAYED
  SHIPMENT_DELAYED
}

enum OrderEventType {
  ORDER_CREATED
  ORDER_REVIEWED
  ORDER_ASSIGNED
  SUPPLIER_CONFIRMED
  SHIPMENT_CREATED
  SHIPMENT_SHIPPED
  SHIPMENT_DELIVERED
}

enum QuoteCreatorRole {
  ADMIN
  SUPPLIER
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

enum EmailRelatedType {
  ORDER
  QUOTE
}

enum EmailStatus {
  SUCCESS
  FAILED
  PENDING
}

enum InvoiceFileType {
  PDF
  XML
}

enum InvoiceOrderLinkType {
  AUTO
  MANUAL
}

enum ProjectStatus {
  DRAFT
  QUOTING
  QUOTED
  ORDERING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProjectFileType {
  PDF
  DWG
  ZIP
  PNG
  JPG
  JPEG
}

/** 바이어 협업(제안/도면) 프로젝트 — 기존 견적용 Project(ProjectStatus)와 별도 */
enum CollabProjectStatus {
  DRAFT
  OPEN
  CLOSED
  ARCHIVED
}

enum CollabUploadStatus {
  UPLOADING
  COMPLETED
  FAILED
  DELETED
}

enum CollabReplyVisibility {
  PRIVATE
}

enum CollabAuthorPartyType {
  SUPPLIER
  INTERIOR
  LIGHTING
  OTHER
}

enum CollabParticipantStatus {
  INVITED
  ACCEPTED
  REJECTED
}

enum SupplierStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SupplierProductFieldType {
  TEXT
  TEXTAREA
  NUMBER
  SELECT
  BOOLEAN
  DATE
}

enum SupplierProductFieldRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Country {
  id           Int       @id @default(autoincrement())
  country_code String    @unique
  country_name String
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  users        User[]
  orders       Order[]
  quotes       Quote[]
  projects     Project[]
}

model Supplier {
  id                          Int             @id @default(autoincrement())
  company_name                String
  company_code                String?         @unique
  country_code                String          @default("KR")
  business_number             String?
  representative_name         String?
  contact_name                String?
  contact_email               String?
  contact_phone               String?
  address                     String?
  /** 신규 공급사는 기본 ACTIVE(자동 승인·가동). PENDING은 명시적 보류용 */
  status                      SupplierStatus  @default(ACTIVE)
  supplier_code               String?         @unique
  supplier_name               String
  order_email                 String
  cc_email                    String?
  invoice_sender_email        String?
  is_active                   Boolean         @default(true)
  allow_supplier_product_edit Boolean         @default(false)
  /** 건축자재 / 기타상품 — 등록 상품은 항상 이 값과 일치 */
  productCategory ProductCategory @default(CONSTRUCTION) @map("product_category")
  created_at                  DateTime        @default(now())
  updated_at                  DateTime        @updatedAt
  users                       User[]
  categories                  Category[]
  products                    Product[]
  cart_items                  CartItem[]
  order_items                 OrderItem[]
  order_assignments           OrderAssignment[]
  order_suppliers             OrderSupplier[]
  quote_items                 QuoteItem[]
  quotes                      Quote[]
  email_logs                  EmailLog[]
  invoice_senders             SupplierInvoiceSender[]
  email_inboxes               EmailInbox[]
  tax_invoices                TaxInvoice[]
  purchase_orders             PurchaseOrder[]
  purchase_order_templates    PurchaseOrderTemplate[]
  product_forms               SupplierProductForm[]
  product_field_requests      SupplierProductFieldRequest[]
  collab_replies              CollabProjectReply[]
  collab_participants         CollabProjectParticipant[]

  @@index([status, country_code])
}

model SupplierInvoiceSender {
  id          Int      @id @default(autoincrement())
  supplier_id Int
  sender_email String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  supplier    Supplier @relation(fields: [supplier_id], references: [id])

  @@unique([sender_email])
  @@index([supplier_id, is_active])
}

model Category {
  id            Int        @id @default(autoincrement())
  supplier_id   Int
  category_name String
  sort_order    Int        @default(0)
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  supplier      Supplier   @relation(fields: [supplier_id], references: [id])
  products      Product[]
  order_items   OrderItem[]
  quote_items   QuoteItem[]

  @@unique([supplier_id, category_name])
  @@index([supplier_id, is_active])
}

model Product {
  id                Int        @id @default(autoincrement())
  supplier_id       Int
  category_id       Int
  productCategory ProductCategory @map("product_category")
  country_code      String
  name_original     String
  description_original String?
  source_language   Language   @default(ko)
  name              String?
  sku               String?
  description       String?
  specification     String?
  product_code      String
  product_name      String
  image_url         String?
  currency          String     @default("KRW")
  status            ProductStatus @default(APPROVED)
  rejection_reason  String?
  spec              String
  unit              String
  price             Decimal    @db.Decimal(18, 2)
  memo              String?
  is_active         Boolean    @default(true)
  sort_order        Int        @default(0)
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt
  supplier          Supplier   @relation(fields: [supplier_id], references: [id])
  category          Category   @relation(fields: [category_id], references: [id])
  cart_items        CartItem[]
  order_items       OrderItem[]
  quote_items       QuoteItem[]
  approval_logs     ProductApprovalLog[]
  translations      ProductTranslation[]
  field_values      SupplierProductFieldValue[]

  @@unique([supplier_id, product_code])
  @@index([supplier_id, status])
  @@index([country_code, is_active, status])
  @@index([supplier_id, category_id, is_active])
  @@index([productCategory])
  @@index([supplier_id, productCategory])
  @@index([product_name])
}

model ProductTranslation {
  id          Int      @id @default(autoincrement())
  product_id  Int
  language    Language
  name        String
  description String?
  is_auto     Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  product     Product  @relation(fields: [product_id], references: [id])

  @@unique([product_id, language])
  @@index([language])
}

model SupplierProductForm {
  id         Int      @id @default(autoincrement())
  supplier_id Int
  name       String
  is_active  Boolean  @default(true)
  created_by Int?
  updated_by Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  supplier   Supplier @relation(fields: [supplier_id], references: [id])
  creator    User?    @relation("SupplierProductFormCreatedBy", fields: [created_by], references: [id])
  updater    User?    @relation("SupplierProductFormUpdatedBy", fields: [updated_by], references: [id])
  fields     SupplierProductField[]

  @@index([supplier_id, is_active])
  @@index([created_by])
  @@index([updated_by])
}

model SupplierProductField {
  id               Int       @id @default(autoincrement())
  form_id          Int
  field_key        String
  field_label      String
  field_type       SupplierProductFieldType
  is_required      Boolean   @default(false)
  is_enabled       Boolean   @default(true)
  /** 바이어 카탈로그·장바구니 리스트 대표 표시명 */
  is_primary_name  Boolean   @default(false)
  /** 바이어 카탈로그·장바구니 리스트 대표 단가 (NUMBER 필드만 유효) */
  is_primary_price Boolean   @default(false)
  sort_order       Int       @default(0)
  placeholder_text String?
  help_text        String?
  validation_json  Json?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  form             SupplierProductForm @relation(fields: [form_id], references: [id])
  values           SupplierProductFieldValue[]

  @@unique([form_id, field_key])
  @@index([form_id, is_enabled, sort_order])
}

model SupplierProductFieldValue {
  id         Int      @id @default(autoincrement())
  product_id Int
  field_id   Int
  value_text String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  product    Product  @relation(fields: [product_id], references: [id])
  field      SupplierProductField @relation(fields: [field_id], references: [id])

  @@unique([product_id, field_id])
  @@index([field_id])
}

model SupplierProductFieldRequest {
  id                    Int      @id @default(autoincrement())
  supplier_id           Int
  request_title         String
  requested_field_label String
  requested_field_type  SupplierProductFieldType
  request_reason        String
  status                SupplierProductFieldRequestStatus @default(PENDING)
  reviewed_by           Int?
  reviewed_at           DateTime?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  supplier              Supplier  @relation(fields: [supplier_id], references: [id])
  reviewer              User?     @relation("SupplierProductFieldRequestReviewedBy", fields: [reviewed_by], references: [id])

  @@index([supplier_id, status, created_at])
  @@index([reviewed_by])
}

model User {
  id                    Int              @id @default(autoincrement())
  login_id              String           @unique
  password_hash         String
  name                  String
  email                 String?
  contact_phone         String?
  role                  Role
  language              Language         @default(en)
  country_id            Int?
  supplier_id           Int?
  is_active             Boolean          @default(true)
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt
  country               Country?         @relation(fields: [country_id], references: [id])
  supplier              Supplier?        @relation(fields: [supplier_id], references: [id])
  buyer_orders          Order[]          @relation("BuyerOrders")
  buyer_quotes          Quote[]          @relation("BuyerQuotes")
  projects              Project[]         @relation("BuyerProjects")
  created_projects      Project[]         @relation("ProjectCreatedBy")
  created_quotes        Quote[]          @relation("CreatorQuotes")
  order_change_logs     OrderChangeLog[] @relation("OrderChangeBy")
  sent_order_suppliers  OrderSupplier[]  @relation("OrderSentBy")
  checked_order_records OrderSupplier[]  @relation("SupplierCheckedBy")
  order_assignments     OrderAssignment[] @relation("OrderAssignmentBy")
  project_files         ProjectFile[]    @relation("ProjectFileUploadedBy")
  audit_logs            AuditLog[]       @relation("AuditActor")
  created_purchase_orders PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  product_approval_logs ProductApprovalLog[] @relation("ProductApprovalActor")
  updated_system_settings SystemSetting[] @relation("SystemSettingUpdatedBy")
  shipment_status_logs  ShipmentStatusLog[] @relation("ShipmentStatusLogCreatedBy")
  notification_recipients NotificationRecipient[]
  po_pdf_download_logs    PoPdfDownloadLog[]     @relation("PoPdfDownloadBy")
  order_event_logs     OrderEventLog[] @relation("OrderEventCreatedBy")
  buyer_status_updated_orders Order[] @relation("BuyerOrderStatusUpdatedBy")
  supplier_status_updated_shipments Shipment[] @relation("SupplierShipmentStatusUpdatedBy")
  created_supplier_product_forms SupplierProductForm[] @relation("SupplierProductFormCreatedBy")
  updated_supplier_product_forms SupplierProductForm[] @relation("SupplierProductFormUpdatedBy")
  reviewed_supplier_product_field_requests SupplierProductFieldRequest[] @relation("SupplierProductFieldRequestReviewedBy")
  buyer_cart        Cart?
  collab_projects_as_buyer              CollabProject[]              @relation("CollabProjectBuyer")
  collab_projects_created               CollabProject[]              @relation("CollabProjectCreatedBy")
  collab_project_files_uploaded         CollabProjectFile[]          @relation("CollabProjectFileUploader")
  collab_replies_authored               CollabProjectReply[]         @relation("CollabReplyAuthor")
  collab_reply_files_uploaded           CollabProjectReplyFile[]     @relation("CollabReplyFileUploader")

  @@index([role, is_active])
  @@index([country_id])
  @@index([supplier_id])
}

model Cart {
  id         Int        @id @default(autoincrement())
  buyer_id   Int        @unique
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt
  buyer      User       @relation(fields: [buyer_id], references: [id], onDelete: Cascade)
  items      CartItem[]

  @@index([buyer_id])
}

model CartItem {
  id             Int      @id @default(autoincrement())
  cart_id        Int
  product_id     Int
  supplier_id    Int
  quantity       Decimal  @db.Decimal(18, 3)
  price_snapshot Decimal  @db.Decimal(18, 2)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  cart           Cart     @relation(fields: [cart_id], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  supplier       Supplier @relation(fields: [supplier_id], references: [id], onDelete: Cascade)

  @@unique([cart_id, product_id])
  @@index([cart_id])
  @@index([supplier_id])
}

model SystemSetting {
  id         Int      @id @default(autoincrement())
  setting_key String  @unique
  value_json Json
  updated_by Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  updater    User?    @relation("SystemSettingUpdatedBy", fields: [updated_by], references: [id])
}

model ProductApprovalLog {
  id            Int                   @id @default(autoincrement())
  product_id    Int
  action        ProductApprovalAction
  actor_user_id Int
  reason        String?
  created_at    DateTime              @default(now())
  product       Product               @relation(fields: [product_id], references: [id])
  actor         User                  @relation("ProductApprovalActor", fields: [actor_user_id], references: [id])

  @@index([product_id, created_at])
  @@index([actor_user_id, created_at])
}

model Project {
  id          Int           @id @default(autoincrement())
  project_name String
  buyer_id    Int
  country_id  Int
  status      ProjectStatus @default(DRAFT)
  memo        String?
  location    String?
  start_date  DateTime?
  end_date    DateTime?
  created_by  Int
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt
  buyer       User          @relation("BuyerProjects", fields: [buyer_id], references: [id])
  creator     User          @relation("ProjectCreatedBy", fields: [created_by], references: [id])
  country     Country       @relation(fields: [country_id], references: [id])
  orders      Order[]
  quotes      Quote[]
  files       ProjectFile[]
  collab_links CollabProject[] @relation("CollabProjectLegacy")

  @@index([buyer_id, country_id, status])
  @@index([created_by, created_at])
}

model ProjectFile {
  id          Int      @id @default(autoincrement())
  project_id  Int
  file_name   String
  original_name String
  file_size   Int
  file_type   ProjectFileType
  file_url    String
  uploaded_by Int
  created_at  DateTime @default(now())
  project     Project  @relation(fields: [project_id], references: [id])
  uploader    User     @relation("ProjectFileUploadedBy", fields: [uploaded_by], references: [id])

  @@index([project_id, created_at])
}

model Order {
  id            Int              @id @default(autoincrement())
  order_no      String           @unique
  buyer_id      Int
  country_id    Int
  country_code  String
  project_id    Int?
  status        OrderStatus      @default(PENDING)
  buyer_status  BuyerOrderStatus @default(ORDER_CREATED)
  buyer_status_updated_by Int?
  buyer_status_updated_at DateTime?
  memo          String?
  /** 통합 발주서 PDF 상대 경로 (주문 생성 시 스냅샷 저장, 예: storage/order-pdfs/2026/order-1-combined.pdf) */
  combined_po_pdf_path String?   @db.VarChar(512)
  combined_pdf_status  OsPdfStatus @default(PENDING)
  combined_pdf_last_error String? @db.Text
  combined_pdf_generated_at DateTime?
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  buyer         User             @relation("BuyerOrders", fields: [buyer_id], references: [id])
  country       Country          @relation(fields: [country_id], references: [id])
  project       Project?         @relation(fields: [project_id], references: [id])
  order_items   OrderItem[]
  suppliers     OrderSupplier[]
  change_logs   OrderChangeLog[]
  tax_invoices  TaxInvoice[]
  purchase_orders PurchaseOrder[]
  event_logs    OrderEventLog[]
  buyer_status_updater User?     @relation("BuyerOrderStatusUpdatedBy", fields: [buyer_status_updated_by], references: [id])
  po_pdf_download_logs PoPdfDownloadLog[]

  @@index([buyer_id, country_id, status])
  @@index([buyer_id, buyer_status])
  @@index([project_id])
}

model OrderItem {
  id                    Int      @id @default(autoincrement())
  order_id              Int
  supplier_id           Int
  status                OrderItemStatus @default(CREATED)
  assigned_by           Int?
  assigned_at           DateTime?
  assignment_mode       AssignmentMode?
  category_id           Int?
  product_id            Int
  product_code_snapshot String
  product_name_snapshot String
  spec_snapshot         String
  unit_snapshot         String
  price_snapshot        Decimal  @db.Decimal(18, 2)
  qty                   Decimal  @db.Decimal(18, 3)
  amount                Decimal  @db.Decimal(18, 2)
  memo                  String?
  created_at            DateTime @default(now())
  order                 Order    @relation(fields: [order_id], references: [id])
  supplier              Supplier @relation(fields: [supplier_id], references: [id])
  category              Category? @relation(fields: [category_id], references: [id])
  product               Product  @relation(fields: [product_id], references: [id])
  change_logs           OrderChangeLog[]
  assignments           OrderAssignment[]
  shipment_items        ShipmentItem[]

  @@index([order_id, supplier_id])
  @@index([order_id, status])
  @@index([supplier_id, status])
  @@index([product_id])
}

model OrderAssignment {
  id            Int      @id @default(autoincrement())
  order_item_id Int
  supplier_id   Int
  assigned_by   Int
  assigned_at   DateTime @default(now())
  order_item    OrderItem @relation(fields: [order_item_id], references: [id])
  supplier      Supplier @relation(fields: [supplier_id], references: [id])
  assignee      User     @relation("OrderAssignmentBy", fields: [assigned_by], references: [id])

  @@index([order_item_id, assigned_at])
  @@index([supplier_id, assigned_at])
  @@index([assigned_by, assigned_at])
}

model OrderSupplier {
  id                  Int                 @id @default(autoincrement())
  order_id            Int
  supplier_id         Int
  status              OrderSupplierStatus @default(PENDING)
  sent_at             DateTime?
  sent_by             Int?
  email_sent          Boolean             @default(false)
  portal_visible      Boolean             @default(false)
  supplier_checked    Boolean             @default(false)
  supplier_checked_at DateTime?
  supplier_checked_by Int?
  supplier_confirmed_at DateTime?
  expected_delivery_date DateTime?
  supplier_note      String?
  /** 공급사별 발주서 PDF 상대 경로 (주문 생성 시 스냅샷) */
  supplier_po_pdf_path String?          @db.VarChar(512)
  /** PDF 헤더에 인쇄된 PO 참조 (주문일 기준 연도·고정 번호) */
  po_snapshot_ref     String?          @db.VarChar(128)
  pdf_status          OsPdfStatus      @default(PENDING)
  pdf_last_error      String?          @db.Text
  pdf_generated_at    DateTime?
  email_status        OsEmailStatus    @default(PENDING)
  email_last_error    String?          @db.Text
  email_sent_at       DateTime?
  email_sent_to       String?          @db.VarChar(512)
  viewed_at           DateTime?
  rejected_at         DateTime?
  completed_at        DateTime?
  tracking_number     String?          @db.VarChar(128)
  reject_reason       String?          @db.Text
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  order               Order               @relation(fields: [order_id], references: [id])
  supplier            Supplier            @relation(fields: [supplier_id], references: [id])
  sender              User?               @relation("OrderSentBy", fields: [sent_by], references: [id])
  checker             User?               @relation("SupplierCheckedBy", fields: [supplier_checked_by], references: [id])
  shipments           Shipment[]
  po_pdf_download_logs PoPdfDownloadLog[]

  @@unique([order_id, supplier_id])
  @@index([status])
}

model PoPdfDownloadLog {
  id                Int               @id @default(autoincrement())
  order_id          Int
  order_supplier_id Int?
  user_id           Int
  role              Role
  download_type     PoPdfDownloadType
  ip                String?           @db.VarChar(64)
  user_agent        String?           @db.VarChar(512)
  downloaded_at     DateTime          @default(now())
  order             Order             @relation(fields: [order_id], references: [id])
  order_supplier    OrderSupplier?    @relation(fields: [order_supplier_id], references: [id])
  user              User              @relation("PoPdfDownloadBy", fields: [user_id], references: [id])

  @@index([order_id, downloaded_at])
  @@index([user_id, downloaded_at])
}

model Shipment {
  id               Int            @id @default(autoincrement())
  order_supplier_id Int
  shipment_no      String         @unique
  carrier          String?
  tracking_number  String?
  status           ShipmentStatus @default(CREATED)
  supplier_status  SupplierShipmentStatus @default(CONFIRMED)
  supplier_status_updated_by Int?
  supplier_status_updated_at DateTime?
  shipped_at       DateTime?
  delivered_at     DateTime?
  created_at       DateTime       @default(now())
  order_supplier   OrderSupplier  @relation(fields: [order_supplier_id], references: [id])
  supplier_status_updater User? @relation("SupplierShipmentStatusUpdatedBy", fields: [supplier_status_updated_by], references: [id])
  items            ShipmentItem[]
  status_logs      ShipmentStatusLog[]

  @@index([order_supplier_id, created_at])
  @@index([status, created_at])
  @@index([supplier_status, created_at])
}

model ShipmentItem {
  id           Int      @id @default(autoincrement())
  shipment_id  Int
  order_item_id Int
  quantity     Decimal  @db.Decimal(18, 3)
  created_at   DateTime @default(now())
  shipment     Shipment @relation(fields: [shipment_id], references: [id])
  order_item   OrderItem @relation(fields: [order_item_id], references: [id])

  @@unique([shipment_id, order_item_id])
  @@index([order_item_id, created_at])
}

model ShipmentStatusLog {
  id             Int      @id @default(autoincrement())
  shipment_id    Int
  status_message String
  created_by     Int
  created_at     DateTime @default(now())
  shipment       Shipment @relation(fields: [shipment_id], references: [id])
  creator        User     @relation("ShipmentStatusLogCreatedBy", fields: [created_by], references: [id])

  @@index([shipment_id, created_at])
  @@index([created_by, created_at])
}

model Notification {
  id         Int               @id @default(autoincrement())
  event_type NotificationEvent
  entity_type String
  entity_id  Int
  message    String
  created_at DateTime          @default(now())
  recipients NotificationRecipient[]

  @@index([event_type, created_at])
  @@index([entity_type, entity_id])
}

model NotificationRecipient {
  id              Int          @id @default(autoincrement())
  notification_id Int
  user_id         Int
  is_read         Boolean      @default(false)
  created_at      DateTime     @default(now())
  notification    Notification @relation(fields: [notification_id], references: [id])
  user            User         @relation(fields: [user_id], references: [id])

  @@unique([notification_id, user_id])
  @@index([user_id, is_read, created_at])
  @@index([notification_id])
}

model OrderEventLog {
  id         Int            @id @default(autoincrement())
  order_id   Int
  event_type OrderEventType
  message    String
  created_by Int
  created_at DateTime       @default(now())
  order      Order          @relation(fields: [order_id], references: [id])
  creator    User           @relation("OrderEventCreatedBy", fields: [created_by], references: [id])

  @@index([order_id, created_at])
  @@index([event_type, created_at])
  @@index([created_by, created_at])
}

model Quote {
  id           Int            @id @default(autoincrement())
  quote_no     String         @unique
  buyer_id     Int
  country_id   Int
  project_id   Int?
  created_by   Int
  creator_role QuoteCreatorRole
  supplier_id  Int?
  status       QuoteStatus    @default(DRAFT)
  memo         String?
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  buyer        User           @relation("BuyerQuotes", fields: [buyer_id], references: [id])
  country      Country        @relation(fields: [country_id], references: [id])
  project      Project?       @relation(fields: [project_id], references: [id])
  creator      User           @relation("CreatorQuotes", fields: [created_by], references: [id])
  supplier     Supplier?      @relation(fields: [supplier_id], references: [id])
  quote_items  QuoteItem[]

  @@index([buyer_id, country_id, status])
  @@index([project_id])
}

model QuoteItem {
  id                    Int      @id @default(autoincrement())
  quote_id              Int
  supplier_id           Int
  category_id           Int?
  product_id            Int
  product_code_snapshot String
  product_name_snapshot String
  spec_snapshot         String
  unit_snapshot         String
  price_snapshot        Decimal  @db.Decimal(18, 2)
  qty                   Decimal  @db.Decimal(18, 3)
  amount                Decimal  @db.Decimal(18, 2)
  created_at            DateTime @default(now())
  quote                 Quote    @relation(fields: [quote_id], references: [id])
  supplier              Supplier @relation(fields: [supplier_id], references: [id])
  category              Category? @relation(fields: [category_id], references: [id])
  product               Product  @relation(fields: [product_id], references: [id])

  @@index([quote_id, supplier_id])
}

model EmailLog {
  id            Int              @id @default(autoincrement())
  related_type  EmailRelatedType
  related_id    Int
  supplier_id   Int?
  to_email      String
  cc_email      String?
  subject       String
  body_preview  String?
  status        EmailStatus      @default(PENDING)
  error_message String?
  sent_at       DateTime?
  created_at    DateTime         @default(now())
  supplier      Supplier?        @relation(fields: [supplier_id], references: [id])

  @@index([related_type, related_id])
}

model EmailInbox {
  id               Int         @id @default(autoincrement())
  message_id       String?     @unique
  from_email       String
  to_email         String
  subject          String
  body             String?
  supplier_id      Int?
  received_at      DateTime
  attachment_count Int         @default(0)
  processed        Boolean     @default(false)
  created_at       DateTime    @default(now())
  supplier         Supplier?   @relation(fields: [supplier_id], references: [id])
  tax_invoice      TaxInvoice?

  @@index([from_email, received_at])
  @@index([supplier_id, received_at])
}

model TaxInvoice {
  id             Int          @id @default(autoincrement())
  supplier_id    Int?
  order_id       Int?
  order_link_type InvoiceOrderLinkType?
  invoice_number String?
  email_inbox_id Int          @unique
  issue_date     DateTime?
  amount         Decimal?     @db.Decimal(18, 2)
  vat            Decimal?     @db.Decimal(18, 2)
  total          Decimal?     @db.Decimal(18, 2)
  created_at     DateTime     @default(now())
  supplier       Supplier?    @relation(fields: [supplier_id], references: [id])
  order          Order?       @relation(fields: [order_id], references: [id])
  email_inbox    EmailInbox   @relation(fields: [email_inbox_id], references: [id])
  files          InvoiceFile[]

  @@index([supplier_id, created_at])
  @@index([order_id])
}

model InvoiceFile {
  id         Int             @id @default(autoincrement())
  invoice_id Int
  file_name  String
  file_url   String
  file_type  InvoiceFileType
  created_at DateTime        @default(now())
  invoice    TaxInvoice      @relation(fields: [invoice_id], references: [id])

  @@index([invoice_id, file_type])
}

model PurchaseOrder {
  id         Int      @id @default(autoincrement())
  order_id   Int
  supplier_id Int
  file_name  String
  file_url   String
  created_by Int
  created_at DateTime @default(now())
  order      Order    @relation(fields: [order_id], references: [id])
  supplier   Supplier @relation(fields: [supplier_id], references: [id])
  creator    User     @relation("PurchaseOrderCreatedBy", fields: [created_by], references: [id])

  @@unique([order_id, supplier_id])
  @@index([supplier_id, created_at])
}

model PurchaseOrderTemplate {
  id            Int       @id @default(autoincrement())
  supplier_id   Int?
  template_name String
  title_ko      String    @default("발주서")
  title_en      String    @default("Purchase Order")
  buyer_name    String?
  footer_note   String?
  is_default    Boolean   @default(false)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  supplier      Supplier? @relation(fields: [supplier_id], references: [id])

  @@index([supplier_id, is_active])
  @@index([is_default, is_active])
}

model CollabProject {
  id                 Int                 @id @default(autoincrement())
  buyer_id           Int
  organization_id    Int?
  title              String
  description        String              @db.Text
  status             CollabProjectStatus @default(DRAFT)
  created_by_user_id Int
  legacy_project_id  Int?
  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt
  deleted_at         DateTime?

  buyer          User                       @relation("CollabProjectBuyer", fields: [buyer_id], references: [id])
  creator        User                       @relation("CollabProjectCreatedBy", fields: [created_by_user_id], references: [id])
  legacy_project Project?                   @relation("CollabProjectLegacy", fields: [legacy_project_id], references: [id])
  files          CollabProjectFile[]
  replies        CollabProjectReply[]
  participants   CollabProjectParticipant[]

  @@index([buyer_id, created_at(sort: Desc)])
  @@index([status, created_at(sort: Desc)])
  @@index([organization_id, created_at(sort: Desc)])
  @@map("collab_projects")
}

model CollabProjectFile {
  id                  Int                @id @default(autoincrement())
  project_id          Int
  storage_key         String?            @unique
  original_filename   String
  mime_type           String
  size_bytes          BigInt
  ext                 String?
  checksum_sha256     String?
  r2_etag             String?
  upload_status       CollabUploadStatus @default(UPLOADING)
  uploaded_by_user_id Int
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  deleted_at          DateTime?

  project  CollabProject @relation(fields: [project_id], references: [id])
  uploader User          @relation("CollabProjectFileUploader", fields: [uploaded_by_user_id], references: [id])

  @@index([project_id, created_at(sort: Desc)])
  @@index([project_id, upload_status])
  @@map("collab_project_files")
}

model CollabProjectReply {
  id                   Int                   @id @default(autoincrement())
  project_id           Int
  body                 String                @db.Text
  author_user_id       Int
  author_supplier_id   Int?
  author_party_type    CollabAuthorPartyType?
  visibility           CollabReplyVisibility @default(PRIVATE)
  created_at           DateTime              @default(now())
  updated_at           DateTime              @updatedAt
  deleted_at           DateTime?

  project         CollabProject            @relation(fields: [project_id], references: [id])
  author          User                   @relation("CollabReplyAuthor", fields: [author_user_id], references: [id])
  author_supplier Supplier?              @relation(fields: [author_supplier_id], references: [id])
  files           CollabProjectReplyFile[]

  @@index([project_id, created_at(sort: Desc)])
  @@index([author_supplier_id, project_id, created_at(sort: Desc)])
  @@index([project_id, author_supplier_id])
  @@map("collab_project_replies")
}

model CollabProjectReplyFile {
  id                  Int                @id @default(autoincrement())
  reply_id            Int
  storage_key         String?            @unique
  original_filename   String
  mime_type           String
  size_bytes          BigInt
  ext                 String?
  checksum_sha256     String?
  r2_etag             String?
  upload_status       CollabUploadStatus @default(UPLOADING)
  uploaded_by_user_id Int
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  deleted_at          DateTime?

  reply    CollabProjectReply @relation(fields: [reply_id], references: [id])
  uploader User               @relation("CollabReplyFileUploader", fields: [uploaded_by_user_id], references: [id])

  @@index([reply_id, created_at(sort: Desc)])
  @@index([reply_id, upload_status])
  @@map("collab_project_reply_files")
}

model CollabProjectParticipant {
  id          Int                     @id @default(autoincrement())
  project_id  Int
  supplier_id Int
  status      CollabParticipantStatus @default(INVITED)
  created_at  DateTime                @default(now())
  updated_at  DateTime                @updatedAt

  project  CollabProject @relation(fields: [project_id], references: [id])
  supplier Supplier      @relation(fields: [supplier_id], references: [id])

  @@unique([project_id, supplier_id])
  @@map("collab_project_participants")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actor_id    Int
  action_type String
  target_type String
  target_id   Int
  before_data Json?
  after_data  Json?
  created_at  DateTime @default(now())
  actor       User     @relation("AuditActor", fields: [actor_id], references: [id])

  @@index([target_type, target_id])
  @@index([actor_id, created_at])
}

model OrderChangeLog {
  id            Int       @id @default(autoincrement())
  order_id      Int
  order_item_id Int?
  action_type   String
  before_data   Json?
  after_data    Json?
  changed_by    Int
  created_at    DateTime  @default(now())
  order         Order     @relation(fields: [order_id], references: [id])
  order_item    OrderItem? @relation(fields: [order_item_id], references: [id])
  changed_user  User      @relation("OrderChangeBy", fields: [changed_by], references: [id])

  @@index([order_id, created_at])
}
